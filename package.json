{
  "name": "repoyear",
  "private": true,
  "version": "0.8.1",
  "type": "module",
  "scripts": {
    "dev": "npm run generate:api:watch & vite",
    "build": "npm run generate:api && vite build",
    "preview": "vite preview",
    "vitest": "vitest",
    "vitest:ui": "vitest --ui",
    "vitest:run": "vitest run",
    "generate:api": "scripts/generate-api.sh",
    "generate:api:watch": "chokidar src/api/openapi.json -c 'npm run generate:api' --initial --silent",
    "generate:graphql": "deno run -A npm:@graphql-codegen/cli/graphql-codegen-esm --config src/github/codegen_config.ts",
    "generate:fixture": "deno run -A scripts/generate-fixture.ts"
  },
  "dependencies": {
    "@deno/vite-plugin": "^2.0.2",
    "@octokit/core": "^7.0.6",
    "@octokit/graphql": "^9.0.3",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.2",
    "fast-deep-equal": "^3.1.3",
    "idb-keyval": "^6.2.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^7.0.1",
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/typescript": "^6.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.8",
    "chokidar-cli": "^3.0.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
